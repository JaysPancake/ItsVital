{
  "name": "itsvital",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Browser-based patient-monitor simulation for education and training.",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @itsvital/server --filter @itsvital/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && node e2e/run-e2e.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
